[Unit]
Description=Add secondary private IPs for multi-EIP routing
After=network-online.target
Wants=network-online.target
Before=tablement.service

[Service]
Type=oneshot
ExecStart=/bin/bash /home/ubuntu/tablement/deploy/secondary-ips.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
SyslogIdentifier=secondary-ips

[Install]
WantedBy=multi-user.target
